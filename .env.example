# =============================================================
# Environment configuration — copy this file to `.env` and fill
# in real values. The `.env` file is git-ignored; NEVER commit it.
#
#   cp .env.example .env
# =============================================================

# Password for the Redis instance (required).
# Generate a strong one with:  openssl rand -hex 16
REDIS_PASSWORD=change-me-to-a-generated-secret
